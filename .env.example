# ============================================
# ORIGINE.DIGITAL – Environment Variables Template
# Copy this to .env.local and fill in your keys
# ============================================
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase (Free: 500MB PostgreSQL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEYS=YOUR_SECRET_KEYS
SUPABASE_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Stripe (Pay-per-use)
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_KEY

# AI Models
OPENAI_API_KEY=sk-YOUR_KEY
DEEPSEEK_API_KEY=sk-YOUR_KEY
MISTRAL_API_KEY=YOUR_KEY

# Brevo (300 emails/day free)
BREVO_API_KEY=xkeysib-YOUR_KEY

# Twitter/X API
TWITTER_API_KEY=YOUR_KEY
TWITTER_API_KEY_SECRET=YOUR_SECRET
TWITTER_BEARER_TOKEN=YOUR_TOKEN
TWITTER_ACCESS_TOKEN=YOUR_TOKEN
TWITTER_ACCESS_TOKEN_SECRET=YOUR_SECRET

# HubSpot (Free CRM)
HUBSPOT_API_KEY=YOUR_KEY

# Mailchimp (500 contacts free)
MAILCHIMP_API_KEY=YOUR_KEY

# GitHub
GITHUB_TOKEN=YOUR_TOKEN

# Vercel
VERCEL_TOKEN=YOUR_TOKEN

# Ko-fi
KOFI_API_KEY=YOUR_KEY

# Admin
ADMIN_EMAIL=maya@originedigital.ie
SUPPORT_EMAIL=support@originedigital.ie
